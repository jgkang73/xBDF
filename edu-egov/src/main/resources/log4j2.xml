<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="logPath">/logs/egov</Property>
        <Property name="pattern">
            [%d{yyyy-MM-dd HH:mm:ss}] [%p] [%c{1}] - %m%n
        </Property>
    </Properties>

    <Appenders>
        <!-- 콘솔 로그 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${pattern}"/>
        </Console>

        <!-- 파일 로그 -->
        <RollingFile name="RollingFile"
                     fileName="${logPath}/application.log"
                     filePattern="${logPath}/application-%d{yyyy-MM-dd}.log">

            <PatternLayout pattern="${pattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- 넥사크로 요청 로그 -->
        <Logger name="nexacro" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- 전자정부프레임워크 : info에서 debug로 변경 -->
        <Logger name="egovframework" level="debug"/>

        <!-- SQL 로그 -->
        <Logger name="jdbc.sqlonly" level="debug"/>

        <!-- Root : info에서 warn으로 변경, info: 모는정보 콘솔에 출력, warn: 오류정보 콘솔에 출력 -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>
</Configuration>
